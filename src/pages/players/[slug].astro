---
import Base from '../../layouts/Base.astro';
import playerData from '../../data/players.json';

export async function getStaticPaths() {
  return playerData.players.map((p: any) => ({
    params: { slug: p.slug },
    props: { playerSlug: p.slug },
  }));
}

const { playerSlug } = Astro.props;
const player = playerData.players.find((p: any) => p.slug === playerSlug);
const stats = player?.seasons?.['3'];
const avatarFallback = player ? player.name.split(' ').map((n: string) => n[0]).join('').slice(0,2).toUpperCase() : '??';

const schema = player ? {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": player.name,
  "description": stats ? `${player.name} – ${stats.goals ?? 0} goals, ${stats.assists ?? 0} assists in ${stats.apps ?? 0} appearances for ${player.team} in Baller League UK Season 3.` : `${player.name} plays for ${player.team} in Baller League UK.`,
  "affiliation": { "@type": "SportsTeam", "name": player.team, "sport": "Football" },
  "image": player.image ? `/players/${player.image}` : undefined
} : undefined;---

<Base
  title={player ? `${player.name} — Baller League UK Player Profile` : 'Player Not Found'}
  description={player ? `${player.name}${stats ? ` — ${stats.goals ?? 0} goals, ${stats.assists ?? 0} assists in ${stats.apps ?? 0} apps for ${player.team} in Baller League UK Season 3.` : ''}` : 'Player not found.'}
  schema={schema}
  keywords={player ? `${player.name}, ${player.team}, Baller League UK player, ${player.position ?? ''}, Season 3` : ''}
>

  {!player ? (
    <div class="page-header"><div class="container"><h1>Player Not Found</h1><a href="/players">Back to Players</a></div></div>
  ) : (
    <>
      <div class="page-header">
        <div class="container">
          <nav class="breadcrumb"><a href="/">Home</a><span class="breadcrumb-sep">›</span><a href="/players">Players</a><span class="breadcrumb-sep">›</span><span>{player.name}</span></nav>
          <div class="player-hero">
            <div class="player-photo-wrap">
              <img src={`/players/${player.slug}.webp`} alt={player.name} class="player-photo-hero" loading="lazy" onerror="this.hidden=true;this.nextElementSibling.hidden=false" />
              <div class="player-avatar-fallback" hidden>{avatarFallback}</div>
            </div>
            <div class="player-hero-info">
              <div class="player-hero-meta">
                {player.position && <span class="badge badge-green">{player.position}</span>}
                {player.number && <span class="badge badge-gw">#{player.number}</span>}
                {player.age && <span class="text-muted" style="font-size:0.85rem;">Age {player.age}</span>}
              </div>
              <h1 class="player-name">{player.name}</h1>
              {player.teamSlug ? (
                <a href={`/teams/${player.teamSlug}`} class="player-team-link">
                  <img src={`/logos/${player.teamSlug}.svg`} alt="" style="width:20px;height:20px;object-fit:contain;vertical-align:middle;margin-right:6px;" onerror="this.hidden=true" />
                  {player.team}
                </a>
              ) : (
                <span class="text-muted">{player.team}</span>
              )}
            </div>
          </div>
        </div>
      </div>

      <div class="container player-page">
        <div class="player-stats-row grid-4">
          <div class="stat-box"><div class="stat-box-number">{stats?.goals ?? 0}</div><div class="stat-box-label">Goals</div></div>
          <div class="stat-box"><div class="stat-box-number">{stats?.assists ?? 0}</div><div class="stat-box-label">Assists</div></div>
          <div class="stat-box"><div class="stat-box-number">{stats?.apps ?? 0}</div><div class="stat-box-label">Appearances</div></div>
          <div class="stat-box"><div class="stat-box-number">{stats?.apps ? ((stats.goals || 0) / stats.apps).toFixed(2) : '—'}</div><div class="stat-box-label">Goals / Game</div></div>
        </div>

        {stats?.detailed && Object.keys(stats.detailed).length > 0 && (
          <div class="player-detailed card">
            <div class="card-body">
              <h3 class="detail-heading">Detailed Stats</h3>
              <div class="detail-grid">
                {Object.entries(stats.detailed).slice(0, 12).map(([key, val]: any) => (
                  <div class="detail-item">
                    <span class="detail-val">{val}</span>
                    <span class="detail-key">{key}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        )}

        <div class="player-cta">
          {player.teamSlug && <a href={`/teams/${player.teamSlug}`} class="btn btn-secondary">View {player.team}</a>}
          <a href="/players" class="btn btn-ghost">All Players</a>
          <a href="/table" class="btn btn-ghost">League Table</a>
        </div>
      </div>
    </>
  )}
</Base>

<style>
.player-hero { display: flex; align-items: center; gap: var(--space-xl); }
.player-photo-wrap { position: relative; flex-shrink: 0; }
.player-photo-hero { width: 120px; height: 120px; border-radius: 50%; object-fit: cover; border: 3px solid var(--green); box-shadow: var(--shadow-green); }
.player-avatar-fallback {
  width: 120px; height: 120px; border-radius: 50%;
  background: linear-gradient(135deg, var(--bg-elevated), var(--bg-card));
  border: 3px solid var(--green);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display); font-size: 3rem; color: var(--green);
  box-shadow: var(--shadow-green);
}
.player-hero-info { flex: 1; }
.player-hero-meta { display: flex; align-items: center; gap: var(--space-sm); margin-bottom: var(--space-sm); flex-wrap: wrap; }
.player-name { margin-bottom: var(--space-sm); font-size: 2rem; }
.player-team-link { color: var(--green); font-weight: 600; font-size: 1.05rem; transition: color var(--transition); display: inline-flex; align-items: center; }
.player-team-link:hover { color: var(--green-mid); }
.badge-gw { background: var(--bg-elevated); color: var(--text-secondary); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.04em; }

.player-page { padding-bottom: var(--space-3xl); }
.player-stats-row { margin-bottom: var(--space-xl); }
.player-detailed { margin-bottom: var(--space-xl); }
.detail-heading { font-size: 0.85rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text-muted); margin-bottom: var(--space-lg); font-family: var(--font-body); }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: var(--space-md); }
.detail-item { background: var(--bg-elevated); border: 1px solid var(--border); border-radius: var(--radius); padding: var(--space-md); text-align: center; }
.detail-val { display: block; font-family: var(--font-display); font-size: 1.8rem; color: var(--text-primary); line-height: 1; }
.detail-key { display: block; font-size: 0.68rem; color: var(--text-muted); margin-top: 4px; text-transform: uppercase; letter-spacing: 0.04em; }
.player-cta { display: flex; gap: var(--space-sm); flex-wrap: wrap; }

@media (max-width: 768px) {
  .detail-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 640px) {
  .player-hero { flex-direction: column; text-align: center; }
  .player-hero-meta { justify-content: center; }
  .detail-grid { grid-template-columns: 1fr 1fr; }
}
</style>
