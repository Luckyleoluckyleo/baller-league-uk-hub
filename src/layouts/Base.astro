---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  image?: string;
  type?: string;
  schema?: object | object[];
  keywords?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  image = '/og-default.png',
  type = 'website',
  schema,
  keywords,
  noindex = false,
} = Astro.props;

const siteTitle = title.includes('Baller League UK')
  ? title
  : `${title} | Baller League UK Hub`;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ballerleagueukhub.com');
const ogImage = new URL(image, Astro.site ?? 'https://ballerleagueukhub.com');

const defaultKeywords = 'Baller League UK, Baller League, 6v6 football, celebrity football league, UK football, Sky Sports, Twitch, KSI, Angry Ginge, Niko Omilana';
const metaKeywords = keywords ? `${keywords}, ${defaultKeywords}` : defaultKeywords;

const schemas = Array.isArray(schema) ? schema : schema ? [schema] : [];

schemas.push({
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Baller League UK Hub",
  "url": "https://ballerleagueukhub.com",
  "description": "The unofficial Baller League UK fan hub. Live table, fixtures, team profiles, player stats, Gamechanger analysis, roundups and news.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "https://ballerleagueukhub.com/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
});

const jsonLd = JSON.stringify(schemas.length === 1 ? schemas[0] : { "@context": "https://schema.org", "@graph": schemas });
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{siteTitle}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={metaKeywords} />
  <meta name="author" content="Baller League UK Hub" />
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
  <meta name="theme-color" content="#06060e" />
  <meta name="format-detection" content="telephone=no" />
  <link rel="canonical" href={canonicalURL} />
  <link rel="sitemap" href="/sitemap.xml" />

  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7873503560434517" crossorigin="anonymous"></script>

  <meta property="og:title"       content={siteTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type"        content={type} />
  <meta property="og:url"         content={canonicalURL} />
  <meta property="og:site_name"   content="Baller League UK Hub" />
  <meta property="og:locale"      content="en_GB" />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={siteTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image"       content={ogImage} />

  <meta name="geo.region" content="GB" />
  <meta name="geo.placename" content="United Kingdom" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <script type="application/ld+json" set:html={jsonLd} />

</head>
<body>
  <Nav />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
  <script>
    (function() {
      const bc = document.querySelector('.breadcrumb');
      if (!bc) return;
      const items = [];
      let pos = 1;
      bc.childNodes.forEach(node => {
        if (node.classList && node.classList.contains('breadcrumb-sep')) return;
        const a = node.tagName === 'A' ? node : null;
        const name = (a || node).textContent.trim();
        if (!name) return;
        items.push({
          "@type": "ListItem",
          "position": pos++,
          "name": name,
          "item": a ? a.href : undefined
        });
      });
      if (items.length < 2) return;
      const ld = {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": items
      };
      const el = document.createElement('script');
      el.type = 'application/ld+json';
      el.textContent = JSON.stringify(ld);
      document.head.appendChild(el);
    })();
  </script>
</body>
</html>
